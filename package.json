{
  "name": "racemate",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "overrides": {
      "postcss": "8.5.10"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "node worker/index.mjs",
    "worker:rss": "node worker/index.mjs rss.fetch_all",
    "worker:social": "node worker/index.mjs social.fetch_all",
    "worker:social:reddit": "node worker/index.mjs social.fetch_reddit",
    "worker:social:x": "node worker/index.mjs social.fetch_x",
    "worker:ai": "node worker/index.mjs ai.process_news",
    "worker:ai:retry-fallback": "node worker/index.mjs ai.reprocess_fallback_news",
    "worker:rehighlight": "node worker/index.mjs ai.rehighlight_news",
    "worker:source-images": "node worker/index.mjs news.backfill_source_images",
    "worker:retag": "node worker/index.mjs ai.retag_news",
    "worker:digest": "node worker/index.mjs ai.generate_daily_digest",
    "worker:polls": "node worker/index.mjs polls.generate_next_race",
    "worker:calendar": "node worker/index.mjs jolpica.sync_calendar",
    "worker:results": "node worker/index.mjs jolpica.sync_results",
    "worker:repair-results": "node worker/index.mjs jolpica.repair_race_results",
    "worker:repair-qualifying": "node worker/index.mjs jolpica.repair_qualifying_results",
    "worker:standings": "node worker/index.mjs jolpica.sync_standings",
    "worker:weather": "node worker/index.mjs weather.sync_weekend",
    "worker:laps": "node worker/index.mjs openf1.sync_laps",
    "worker:score": "node worker/index.mjs predictions.score",
    "worker:reports": "node worker/index.mjs reports.check_latest",
    "worker:reports:all": "node worker/index.mjs reports.generate_all_completed",
    "worker:reports:refresh": "node worker/index.mjs reports.refresh_due",
    "worker:reports:summary": "node worker/index.mjs reports.generate_summary",
    "worker:circuit-stats": "node worker/index.mjs circuit_stats.sync_all",
    "supabase:smtp": "node scripts/configure-supabase-smtp.mjs",
    "supabase:auth": "node scripts/configure-supabase-smtp.mjs",
    "lint": "eslint .",
    "test:fantasy-scoring": "node scripts/check-fantasy-scoring.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-slot": "latest",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "geist": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "^9.0.0",
    "eslint-config-next": "latest",
    "tailwindcss": "latest",
    "typescript": "latest"
  }
}
